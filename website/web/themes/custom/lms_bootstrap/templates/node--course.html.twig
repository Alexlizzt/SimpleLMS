<div class="container py-5">

  <div class="row">

    <div class="col-md-8">

      {% if content.field_image %}
        <div class="mb-4">
          {{ content.field_image }}
        </div>
      {% endif %}

      <h1 class="mb-3">{{ label }}</h1>

      <div class="mb-4">
        {{ content.field_description }}
      </div>

      <hr>

      <h3 class="mb-3">Lecciones</h3>

      {{ drupal_view('lecciones_del_curso', 'block_1', node.id) }}
    </div>

    <div class="col-md-4">
      <div class="card shadow-sm">
        <div class="card-body">
          <h5>Inscripción</h5>
          <button class="btn btn-primary w-100">
            Inscribirse
          </button>
        </div>
      </div>
    </div>

  </div>

</div>
