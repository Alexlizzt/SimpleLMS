<!DOCTYPE html>
<html{{ html_attributes }}>
  <head>
    <head-placeholder token="{{ placeholder_token }}">
    <title>{{ head_title|safe_join(' | ') }}</title>
    <css-placeholder token="{{ placeholder_token }}">
    <js-placeholder token="{{ placeholder_token }}">
  </head>
  <body{{ attributes.addClass('d-flex','flex-column','min-vh-100') }}>

    {# ========================= HEADER ========================= #}
    <header>
      <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
          <a class="navbar-brand" href="{{ path('<front>') }}">
            <img src="{{ directory }}/logo.svg" alt="Logo" height="40">
          </a>
          <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent">
            <span class="navbar-toggler-icon"></span>
          </button>
          <div class="collapse navbar-collapse" id="navbarSupportedContent">
            {% if page.primary_menu %}
              {{ page.primary_menu }}
            {% endif %}
          </div>
        </div>
      </nav>
    </header>

    {# ========================= HERO / LANDING ========================= #}
    <section class="hero bg-primary text-white text-center py-5">
      <div class="container">
        <h1 class="display-4 fw-bold">Bienvenido a Simple LMS</h1>
        <p class="lead">Aprende a tu ritmo con nuestros cursos online</p>
        <a href="/cursos" class="btn btn-light btn-lg mt-3">Explorar Cursos</a>
      </div>
    </section>

    {# ========================= GRID DE CURSOS ========================= #}
    <main class="flex-fill py-5">
     <section class="py-5">
        <div class="container">
            <h2 class="mb-4 text-center">Nuestros Cursos</h2>
            {{ drupal_view('cursos', 'page_1') }}
        </div>
    </section>
    </main>

    {# ========================= FOOTER ========================= #}
    <footer class="bg-light py-4 mt-auto">
      <div class="container text-center">
        <div class="row">
          <div class="col-md-4">Contacto: contacto@simplelms.com</div>
          <div class="col-md-4">Enlaces: <a href="#">FAQ</a> | <a href="#">Soporte</a></div>
          <div class="col-md-4">Redes Sociales: <a href="#">Twitter</a> | <a href="#">Facebook</a></div>
        </div>
        <small class="d-block mt-3">© {{ "now"|date("Y") }} Simple LMS</small>
      </div>
    </footer>

    <js-bottom-placeholder token="{{ placeholder_token }}">
  </body>
</html>