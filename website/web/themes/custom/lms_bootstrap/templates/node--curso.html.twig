<div class="container py-5">
  <div class="row">
    <div class="col-md-8">
      <h1 class="mb-3">{{ label }}</h1>

      {% if content.field_imagen %}
        <div class="mb-4 rounded overflow-hidden">
          {{ content.field_imagen }}
        </div>
      {% endif %}

      <div class="mb-4 lead">
        {# Aquí solo imprimimos la descripción pura #}
        {{ content.field_descripcion }}
      </div>

      <hr class="my-5">
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm border-0">
          <div class="card-body p-4 text-center">
            <h4 class="mb-3">¡Comienza hoy!</h4>
            <button class="btn btn-primary btn-lg w-100">
              Inscribirse al curso
            </button>
          </div>
        </div>
      </div>
    </div>
</div>
