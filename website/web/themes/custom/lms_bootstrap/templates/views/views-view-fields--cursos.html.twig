<div class="card h-100 shadow-sm d-flex flex-column">

  {# Imagen con relación de aspecto fija para que no deforme la card #}
  <div class="curso-imagen mb-0" style="aspect-ratio: 16 / 9; overflow: hidden;">
    {{ fields.field_imagen.content }}
  </div>

  <div class="card-body d-flex flex-column flex-grow-1">
    {# Título con altura mínima o truncado si es muy largo #}
    <h5 class="card-title text-primary fw-bold mb-2" style="min-height: 3rem;">
      {{ fields.title.content }}
    </h5>

    {# Descripción con flex-grow para empujar el botón hacia abajo #}
    <div class="card-text text-muted small mb-3 flex-grow-1">
      {{ fields.field_descripcion.content }}
    </div>

    {# El contenedor del botón siempre se irá al fondo gracias al flex-grow del texto #}
    <div class="mt-auto pt-3">
      <a href="{{ path('entity.node.canonical', {'node': row.nid}) }}" class="btn btn-primary w-100">
        Ver curso
      </a>
    </div>
  </div>
</div>
