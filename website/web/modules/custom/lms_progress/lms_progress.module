<?php

use Drupal\node\NodeInterface;
use Drupal\Core\Access\AccessResult;
use Drupal\Core\Entity\EntityInterface;
use Drupal\Core\Mail\MailManagerInterface;

use Symfony\Component\HttpFoundation\RedirectResponse;

/**
 * Implements hook_preprocess_node().
 */
function lms_progress_preprocess_node(&$variables) {
  /** @var \Drupal\node\NodeInterface $node */
  $node = $variables['node'];
  $user_id = Drupal::currentUser()->id();

  // Obtenemos el servicio una sola vez para eficiencia
  $progress_service = Drupal::service('lms_progress.progress_service');

  // Lógica para el nodo tipo LECCIÓN
  if ($node->bundle() === 'leccion') {
    $completed = $progress_service->isLessonCompleted($user_id, $node->id());

    $variables['lesson_completed'] = $completed;

    // Manejo correcto del caché:
    // Impedimos que se cachee para que el check de "completado" cambie al instante
    $variables['#cache']['max-age'] = 0;
  }

  // Lógica para el nodo tipo CURSO
  if ($node->bundle() === 'curso') {
    $progress = $progress_service->getCourseProgress($user_id, $node->id());

    // Nos aseguramos de pasar siempre un número
    $variables['course_progress'] = $progress ? $progress : 0;

    // También invalidamos caché aquí para que la barra suba al completar lecciones
    $variables['#cache']['max-age'] = 0;
  }
}


/**
 * Implements hook_node_access().
 */
function lms_progress_node_access(EntityInterface $node, $op, $account) {

  if ($account instanceof \Drupal\Core\Session\AccountProxyInterface) {
          $account = $account->getAccount();
  }
  if ($op !== 'view') {
    return AccessResult::neutral();
  }

  if ($node->bundle() !== 'leccion') {
    return AccessResult::neutral();
  }

  return AccessResult::allowed();

}


/**
 * Implements hook_node_view().
 */
function lms_progress_node_view(array &$build, NodeInterface $node, $display, $view_mode) {

  if ($node->bundle() !== 'leccion') {
    return;
  }

  $user = Drupal::currentUser();
  $course_id = $node->get('field_curso_padre')->target_id;

  $progress_service = Drupal::service('lms_progress.progress_service');

  if (!$progress_service->isUserEnrolled($user->id(), $course_id)) {

    $course = \Drupal\node\Entity\Node::load($course_id);

    $response = new RedirectResponse($course->toUrl()->toString());
    $response->send();
    exit;

  }

}


/**
 * Implements template_preprocess_views_view_fields().
 */
function lms_progress_preprocess_views_view_fields(&$variables) {
  $view = $variables['view'];

  if ($view->id() == 'mis_cursos') {
    $node = $variables['row']->_entity;

    if ($node instanceof \Drupal\node\NodeInterface) {
      $uid = Drupal::currentUser()->id();

      // 1. Lógica de progreso
      $progress_service = Drupal::service('lms_progress.progress_service');
      $variables['curso_progreso'] = $progress_service->getCourseProgress($uid, $node->id());
      $variables['curso_id'] = $node->id();

      // 2. Lógica de Imagen: Usamos el View Builder para respetar la configuración de Drupal
      $field_name = 'field_imagen';
      if ($node->hasField($field_name)) {
        // Esto genera el render array usando el 'view mode' por defecto o el que prefieras
        $variables['curso_imagen_render'] = $node->get($field_name)->view('teaser');
      }

      // 3. Estado de finalización del curso (para mostrar botón de certificado)
      $variables['course_complete'] = $progress_service->isCourseComplete($uid, $node->id());

      // También puede ser útil pasar el nodo completo o el ID
      $variables['curso_id'] = $node->id();
      $variables['node'] = $node;

      // Evitamos caché para que el botón y el progreso se actualicen inmediatamente
      $variables['#cache']['max-age'] = 0;
      $variables['#cache']['contexts'][] = 'user';
    }
  }
}

/**
 * Implements hook_entity_presave().
 * Este hook se ejecuta justo antes de guardar cualquier entidad (nodo, usuario, etc).
 */
function lms_progress_entity_presave(EntityInterface $entity) {
  // Verificamos que sea un usuario y que sea nuevo (registro)
  if ($entity->getEntityTypeId() === 'user' && $entity->isNew()) {

    // IMPORTANTE: Verifica que el nombre de máquina sea field_user_role
    if ($entity->hasField('field_user_role') && !$entity->get('field_user_role')->isEmpty()) {

      $seleccion = $entity->get('field_user_role')->value;

      // Asignación de roles según la selección
      if ($seleccion === 'instructor') {
        $entity->addRole('instructor');
      }
      elseif ($seleccion === 'estudiante') {
        $entity->addRole('estudiante');
      }
    }
  }
}

/**
 * Implements hook_mail().
 *  Constructor del correo
 */
function lms_progress_mail($key, &$message, $params) {
  switch ($key) {
    case 'course_enrollment':
      $message['subject'] = $params['subject'];
      $message['body'][] = $params['message'];
      break;
    // Pasar los adjuntos al mensaje para que el módulo SMTP los vea
    case 'certificate': // Agregamos este caso
      $message['subject'] = $params['subject'];
      $message['body'][] = $params['message'];

      // Pasar los adjuntos al mensaje para que el módulo SMTP los vea
      if (isset($params['attachments'])) {
        $message['params']['attachments'] = $params['attachments'];
      }
      break;
  }
}

/**
 * Enviar correo de inscripción.
 */
function lms_progress_send_enrollment_email($user, $course) {

  $mailManager = Drupal::service('plugin.manager.mail');

  // Generar la URL absoluta al curso
  $course_url = $course->toUrl('canonical', ['absolute' => TRUE])->toString();

  $module = 'lms_progress';
  $key = 'course_enrollment';
  $to = $user->getEmail();
  $langcode = $user->getPreferredLangcode();

  $params['subject'] = 'Te has inscrito a un curso 🎓';
  $params['message'] = "¡Hola, " . $user->getDisplayName() . "!\n\n" .
    "Es un gusto confirmarte que ya tienes acceso al curso:\n" .
    "👉 " . $course->label() . "\n\n" .
    "Puedes comenzar tu aprendizaje haciendo clic en el siguiente enlace:\n" .
    $course_url . "\n\n" .
    "¡Mucho éxito en tu formación! 🎓";

  // Añadimos NULL para el reply-to y TRUE para enviar inmediatamente
  $mailManager->mail($module, $key, $to, $langcode, $params, NULL, TRUE);
}
